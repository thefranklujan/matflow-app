generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Multi-Tenancy ─────────────────────────────────────

model Gym {
  id                 String    @id @default(cuid())
  clerkOrgId         String    @unique
  name               String
  slug               String    @unique
  logo               String?
  primaryColor       String    @default("#0fe69b")
  secondaryColor     String?
  phone              String?
  website            String?
  timezone           String    @default("America/Chicago")
  stripeCustomerId   String?
  stripePriceId      String?
  subscriptionStatus String    @default("trialing")
  trialEndsAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  members        Member[]
  categories     Category[]
  products       Product[]
  orders         Order[]
  videos         Video[]
  announcements  Announcement[]
  classSchedules ClassSchedule[]
  events         Event[]
}

// ── E-Commerce ────────────────────────────────────────

model Category {
  id        String    @id @default(cuid())
  gymId     String
  gym       Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name      String
  slug      String
  image     String?
  sortOrder Int       @default(0)
  products  Product[]
  createdAt DateTime  @default(now())

  @@unique([gymId, slug])
}

model Product {
  id          String           @id @default(cuid())
  gymId       String
  gym         Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String
  price       Float
  compareAt   Float?
  categoryId  String
  category    Category         @relation(fields: [categoryId], references: [id])
  images      ProductImage[]
  variants    ProductVariant[]
  featured    Boolean          @default(false)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orderItems  OrderItem[]

  @@unique([gymId, slug])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String      @id @default(cuid())
  size       String
  color      String?
  stock      Int         @default(0)
  sku        String?     @unique
  productId  String
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  orderItems OrderItem[]
}

model Order {
  id              String      @id @default(cuid())
  gymId           String
  gym             Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  status          String      @default("pending")
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress String?
  notes           String?
  subtotal        Float
  total           Float
  items           OrderItem[]
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

model OrderItem {
  id        String         @id @default(cuid())
  quantity  Int
  unitPrice Float
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  variantId String
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

// ── Member Portal ──────────────────────────────────────

model Member {
  id                  String              @id @default(cuid())
  gymId               String
  gym                 Gym                 @relation(fields: [gymId], references: [id], onDelete: Cascade)
  clerkUserId         String
  email               String
  firstName           String
  lastName            String
  phone               String?
  beltRank            String              @default("white")
  stripes             Int                 @default(0)
  approved            Boolean             @default(true)
  active              Boolean             @default(true)
  locationSlug        String?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  attendances         Attendance[]
  beltHistory         BeltProgress[]
  competitionResults  CompetitionResult[]
  personalGoals       PersonalGoal[]
  scheduleCommitments ScheduleCommitment[]
  techniqueProgress   TechniqueProgress[]

  @@unique([gymId, clerkUserId])
  @@unique([gymId, email])
}

model Video {
  id          String   @id @default(cuid())
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  title       String
  description String?
  embedUrl    String
  classType   String
  classDate   DateTime
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Attendance {
  id           String   @id @default(cuid())
  gymId        String
  memberId     String
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  classDate    DateTime
  classType    String
  locationSlug String
  checkedInAt  DateTime @default(now())

  @@unique([gymId, memberId, classDate, classType])
}

model BeltProgress {
  id        String   @id @default(cuid())
  gymId     String
  memberId  String
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  beltRank  String
  stripes   Int
  note      String?
  awardedAt DateTime @default(now())
  awardedBy String?
  createdAt DateTime @default(now())
}

model Announcement {
  id          String   @id @default(cuid())
  gymId       String
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
  title       String
  content     String
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
}

model ClassSchedule {
  id           String  @id @default(cuid())
  gymId        String
  gym          Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startTime    String
  endTime      String
  classType    String
  instructor   String
  locationSlug String
  topic        String?
  active       Boolean @default(true)
}

model ScheduleCommitment {
  id           String   @id @default(cuid())
  gymId        String
  memberId     String
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  classDate    DateTime
  classType    String
  locationSlug String
  createdAt    DateTime @default(now())

  @@unique([gymId, memberId, classDate, classType])
}

model TechniqueProgress {
  id          String   @id @default(cuid())
  gymId       String
  memberId    String
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  techniqueId String
  completedAt DateTime @default(now())
  verifiedBy  String?

  @@unique([gymId, memberId, techniqueId])
}

// ── Calendar & Leaderboard ─────────────────────────────

model Event {
  id           String    @id @default(cuid())
  gymId        String
  gym          Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  date         DateTime
  endDate      DateTime?
  eventType    String
  locationSlug String
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CompetitionResult {
  id              String   @id @default(cuid())
  gymId           String
  memberId        String
  member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  competitionName String
  date            DateTime
  placement       String
  division        String?
  notes           String?
  createdAt       DateTime @default(now())
}

model PersonalGoal {
  id           String    @id @default(cuid())
  gymId        String
  memberId     String
  member       Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  title        String
  targetValue  Int
  currentValue Int       @default(0)
  goalType     String
  startDate    DateTime
  endDate      DateTime?
  completed    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}
