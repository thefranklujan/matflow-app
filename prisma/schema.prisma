generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Gym {
  id                 String          @id @default(cuid())
  clerkOrgId         String          @unique
  name               String
  slug               String          @unique
  logo               String?
  primaryColor       String          @default("#0fe69b")
  secondaryColor     String?
  phone              String?
  website            String?
  timezone           String          @default("America/Chicago")
  stripeCustomerId   String?
  stripePriceId      String?
  subscriptionStatus String          @default("trialing")
  trialEndsAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  announcements      Announcement[]
  categories         Category[]
  classSchedules     ClassSchedule[]
  events             Event[]
  members            Member[]
  orders             Order[]
  products           Product[]
  videos             Video[]
}

model Category {
  id        String    @id @default(cuid())
  gymId     String
  name      String
  slug      String
  image     String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  gym       Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([gymId, slug])
}

model Product {
  id          String           @id @default(cuid())
  gymId       String
  name        String
  slug        String
  description String
  price       Float
  compareAt   Float?
  categoryId  String
  featured    Boolean          @default(false)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orderItems  OrderItem[]
  category    Category         @relation(fields: [categoryId], references: [id])
  gym         Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  images      ProductImage[]
  variants    ProductVariant[]

  @@unique([gymId, slug])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String      @id @default(cuid())
  size       String
  color      String?
  stock      Int         @default(0)
  sku        String?     @unique
  productId  String
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  gymId           String
  status          String      @default("pending")
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress String?
  notes           String?
  subtotal        Float
  total           Float
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  gym             Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  items           OrderItem[]
}

model OrderItem {
  id        String         @id @default(cuid())
  quantity  Int
  unitPrice Float
  orderId   String
  productId String
  variantId String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

model Member {
  id                  String               @id @default(cuid())
  gymId               String
  clerkUserId         String
  email               String
  firstName           String
  lastName            String
  phone               String?
  passwordHash        String?
  beltRank            String               @default("white")
  stripes             Int                  @default(0)
  approved            Boolean              @default(true)
  active              Boolean              @default(true)
  locationSlug        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  attendances         Attendance[]
  beltHistory         BeltProgress[]
  competitionResults  CompetitionResult[]
  gym                 Gym                  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  personalGoals       PersonalGoal[]
  scheduleCommitments ScheduleCommitment[]
  techniqueProgress   TechniqueProgress[]

  @@unique([gymId, clerkUserId])
  @@unique([gymId, email])
}

model Video {
  id          String   @id @default(cuid())
  gymId       String
  title       String
  description String?
  embedUrl    String
  classType   String
  classDate   DateTime
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model Attendance {
  id           String   @id @default(cuid())
  gymId        String
  memberId     String
  classDate    DateTime
  classType    String
  locationSlug String
  checkedInAt  DateTime @default(now())
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([gymId, memberId, classDate, classType])
}

model BeltProgress {
  id        String   @id @default(cuid())
  gymId     String
  memberId  String
  beltRank  String
  stripes   Int
  note      String?
  awardedAt DateTime @default(now())
  awardedBy String?
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String   @id @default(cuid())
  gymId       String
  title       String
  content     String
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model ClassSchedule {
  id           String  @id @default(cuid())
  gymId        String
  dayOfWeek    Int
  startTime    String
  endTime      String
  classType    String
  instructor   String
  locationSlug String
  topic        String?
  active       Boolean @default(true)
  gym          Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model ScheduleCommitment {
  id           String   @id @default(cuid())
  gymId        String
  memberId     String
  classDate    DateTime
  classType    String
  locationSlug String
  createdAt    DateTime @default(now())
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([gymId, memberId, classDate, classType])
}

model TechniqueProgress {
  id          String   @id @default(cuid())
  gymId       String
  memberId    String
  techniqueId String
  completedAt DateTime @default(now())
  verifiedBy  String?
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([gymId, memberId, techniqueId])
}

model Event {
  id           String    @id @default(cuid())
  gymId        String
  title        String
  description  String?
  date         DateTime
  endDate      DateTime?
  eventType    String
  locationSlug String
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  gym          Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model CompetitionResult {
  id              String   @id @default(cuid())
  gymId           String
  memberId        String
  competitionName String
  date            DateTime
  placement       String
  division        String?
  notes           String?
  createdAt       DateTime @default(now())
  member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model PersonalGoal {
  id           String    @id @default(cuid())
  gymId        String
  memberId     String
  title        String
  targetValue  Int
  currentValue Int       @default(0)
  goalType     String
  startDate    DateTime
  endDate      DateTime?
  completed    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  member       Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
}
