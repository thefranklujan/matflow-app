generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Gym {
  id                 String          @id @default(cuid())
  clerkOrgId         String          @unique
  name               String
  slug               String          @unique
  logo               String?
  primaryColor       String          @default("#0fe69b")
  secondaryColor     String?
  phone              String?
  website            String?
  description        String?
  city               String?
  state              String?
  timezone           String          @default("America/Chicago")
  approved           Boolean         @default(false)
  hidden             Boolean         @default(false)
  lat                Float?
  lng                Float?
  stripeCustomerId   String?
  stripePriceId      String?
  subscriptionStatus String          @default("trialing")
  trialEndsAt        DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  announcements      Announcement[]
  categories         Category[]
  classSchedules     ClassSchedule[]
  events             Event[]
  joinRequests       JoinRequest[]
  leads              Lead[]
  members            Member[]
  orders             Order[]
  products           Product[]
  videos             Video[]
  waiverSignatures   WaiverSignature[]
  waiverTemplates    WaiverTemplate[]
  activityLogs       ActivityLog[]
}

model Category {
  id        String    @id @default(cuid())
  gymId     String
  name      String
  slug      String
  image     String?
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  gym       Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
  products  Product[]

  @@unique([gymId, slug])
}

model Product {
  id          String           @id @default(cuid())
  gymId       String
  name        String
  slug        String
  description String
  price       Float
  compareAt   Float?
  categoryId  String
  featured    Boolean          @default(false)
  active      Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  orderItems  OrderItem[]
  category    Category         @relation(fields: [categoryId], references: [id])
  gym         Gym              @relation(fields: [gymId], references: [id], onDelete: Cascade)
  images      ProductImage[]
  variants    ProductVariant[]

  @@unique([gymId, slug])
}

model ProductImage {
  id        String  @id @default(cuid())
  url       String
  alt       String?
  sortOrder Int     @default(0)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductVariant {
  id         String      @id @default(cuid())
  size       String
  color      String?
  stock      Int         @default(0)
  sku        String?     @unique
  productId  String
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model Order {
  id              String      @id @default(cuid())
  gymId           String
  status          String      @default("pending")
  customerName    String
  customerEmail   String
  customerPhone   String?
  shippingAddress String?
  notes           String?
  subtotal        Float
  total           Float
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  gym             Gym         @relation(fields: [gymId], references: [id], onDelete: Cascade)
  items           OrderItem[]
}

model OrderItem {
  id        String         @id @default(cuid())
  quantity  Int
  unitPrice Float
  orderId   String
  productId String
  variantId String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product        @relation(fields: [productId], references: [id])
  variant   ProductVariant @relation(fields: [variantId], references: [id])
}

model Member {
  id                  String               @id @default(cuid())
  gymId               String
  clerkUserId         String
  email               String
  firstName           String
  lastName            String
  phone               String?
  passwordHash        String?
  studentId           String?
  status              String               @default("active")
  beltRank            String               @default("white")
  stripes             Int                  @default(0)
  approved            Boolean              @default(true)
  active              Boolean              @default(true)
  isAmbassador        Boolean              @default(false)
  checkinCode         String?
  locationSlug        String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  attendances         Attendance[]
  beltHistory         BeltProgress[]
  competitionResults  CompetitionResult[]
  gym                 Gym                  @relation(fields: [gymId], references: [id], onDelete: Cascade)
  student             Student?             @relation(fields: [studentId], references: [id], onDelete: SetNull)
  personalGoals       PersonalGoal[]
  scheduleCommitments ScheduleCommitment[]
  techniqueProgress   TechniqueProgress[]
  waiverSignatures    WaiverSignature[]

  @@unique([gymId, clerkUserId])
  @@unique([gymId, email])
}

model Student {
  id                  String            @id @default(cuid())
  email               String            @unique
  firstName           String
  lastName            String
  phone               String?
  passwordHash        String
  homeGym             String?
  beltRank            String            @default("white")
  stripes             Int               @default(0)
  trainingSince       DateTime?
  shareSchedule       Boolean           @default(true)
  showFriendsSchedule Boolean           @default(true)
  avatarUrl           String?
  weeklyGoal          Int               @default(4)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  joinRequests    JoinRequest[]
  memberships     Member[]
  trainingSessions TrainingSession[]
  nominations     GymNomination[]
  groupMemberships GymGroupMember[]
  groupPosts      GroupPost[]
  postReports     PostReport[]
  trainingPlan    StudentTrainingPlan[]
  postLikes       PostLike[]
  postComments    PostComment[]
}

model StudentTrainingPlan {
  id        String   @id @default(cuid())
  studentId String
  date      DateTime @db.Date
  morning   Boolean  @default(false)
  noon      Boolean  @default(false)
  afternoon Boolean  @default(false)
  gym       String?
  createdAt DateTime @default(now())
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, date])
  @@index([studentId])
}

model GymGroup {
  id          String           @id
  name        String
  city        String?
  state       String?
  memberCount Int              @default(0)
  createdAt   DateTime         @default(now())
  members     GymGroupMember[]
  posts       GroupPost[]
}

model GymGroupMember {
  id        String   @id @default(cuid())
  groupId   String
  studentId String
  role      String   @default("member") // "mod" | "member"
  status    String   @default("active") // "active" | "pending"
  joinedAt  DateTime @default(now())
  group     GymGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([groupId, studentId])
  @@index([studentId])
}

model GroupPost {
  id          String        @id @default(cuid())
  groupId     String
  studentId   String
  body        String
  hidden      Boolean       @default(false)
  hiddenAt    DateTime?
  hiddenBy    String?
  reportCount Int           @default(0)
  createdAt   DateTime      @default(now())
  group       GymGroup      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  student     Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  reports     PostReport[]
  likes       PostLike[]
  comments    PostComment[]

  @@index([groupId])
}

model PostLike {
  id        String    @id @default(cuid())
  postId    String
  studentId String
  createdAt DateTime  @default(now())
  post      GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([postId, studentId])
  @@index([postId])
}

model PostComment {
  id        String    @id @default(cuid())
  postId    String
  studentId String
  body      String
  createdAt DateTime  @default(now())
  post      GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostReport {
  id         String    @id @default(cuid())
  postId     String
  reporterId String
  reason     String?
  createdAt  DateTime  @default(now())
  post       GroupPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  reporter   Student   @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@unique([postId, reporterId])
  @@index([postId])
}

model TrainingSession {
  id          String   @id @default(cuid())
  studentId   String
  date        DateTime
  duration    Int      @default(60)
  sessionType String
  techniques  String?
  partners    String?
  notes       String?
  rollsWon    Int      @default(0)
  rollsLost   Int      @default(0)
  createdAt   DateTime @default(now())
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
}

model GymNomination {
  id         String   @id @default(cuid())
  studentId  String
  gymName    String
  city       String?
  state      String?
  ownerEmail String?
  ownerPhone String?
  notes      String?
  status     String   @default("new")
  createdAt  DateTime @default(now())
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([gymName])
  @@index([studentId])
}

model JoinRequest {
  id        String    @id @default(cuid())
  studentId String
  gymId     String
  status    String    @default("pending")
  message   String?
  decidedAt DateTime?
  decidedBy String?
  createdAt DateTime  @default(now())
  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  gym       Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@unique([studentId, gymId])
}

model Video {
  id          String   @id @default(cuid())
  gymId       String
  title       String
  description String?
  embedUrl    String
  classType   String
  classDate   DateTime
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model Attendance {
  id           String   @id @default(cuid())
  gymId        String
  memberId     String
  classDate    DateTime
  classType    String
  locationSlug String
  checkedInAt  DateTime @default(now())
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([gymId, memberId, classDate, classType])
}

model BeltProgress {
  id        String   @id @default(cuid())
  gymId     String
  memberId  String
  beltRank  String
  stripes   Int
  note      String?
  awardedAt DateTime @default(now())
  awardedBy String?
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Announcement {
  id          String   @id @default(cuid())
  gymId       String
  title       String
  content     String
  pinned      Boolean  @default(false)
  publishedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  gym         Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model ClassSchedule {
  id           String  @id @default(cuid())
  gymId        String
  dayOfWeek    Int
  startTime    String
  endTime      String
  classType    String
  instructor   String
  locationSlug String
  topic        String?
  active       Boolean @default(true)
  gym          Gym     @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model ScheduleCommitment {
  id           String   @id @default(cuid())
  gymId        String
  memberId     String
  classDate    DateTime
  classType    String
  locationSlug String
  createdAt    DateTime @default(now())
  member       Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([gymId, memberId, classDate, classType])
}

model TechniqueProgress {
  id          String   @id @default(cuid())
  gymId       String
  memberId    String
  techniqueId String
  completedAt DateTime @default(now())
  verifiedBy  String?
  member      Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([gymId, memberId, techniqueId])
}

model Event {
  id           String    @id @default(cuid())
  gymId        String
  title        String
  description  String?
  date         DateTime
  endDate      DateTime?
  eventType    String
  locationSlug String
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  gym          Gym       @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model CompetitionResult {
  id              String   @id @default(cuid())
  gymId           String
  memberId        String
  competitionName String
  date            DateTime
  placement       String
  division        String?
  notes           String?
  createdAt       DateTime @default(now())
  member          Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model PersonalGoal {
  id           String    @id @default(cuid())
  gymId        String
  memberId     String
  title        String
  targetValue  Int
  currentValue Int       @default(0)
  goalType     String
  startDate    DateTime
  endDate      DateTime?
  completed    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  member       Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
}

model Lead {
  id        String   @id @default(cuid())
  gymId     String
  firstName String
  lastName  String
  email     String
  phone     String?
  source    String   @default("website")
  status    String   @default("new")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  gym       Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)
}

model WaiverTemplate {
  id         String            @id @default(cuid())
  gymId      String
  title      String
  content    String
  active     Boolean           @default(true)
  version    Int               @default(1)
  createdAt  DateTime          @default(now())
  gym        Gym               @relation(fields: [gymId], references: [id], onDelete: Cascade)
  signatures WaiverSignature[]
}

model WaiverSignature {
  id                    String         @id @default(cuid())
  gymId                 String
  memberId              String
  templateId            String
  signedName            String
  signedAt              DateTime       @default(now())
  waiverContentSnapshot String
  gym                   Gym            @relation(fields: [gymId], references: [id], onDelete: Cascade)
  member                Member         @relation(fields: [memberId], references: [id], onDelete: Cascade)
  template              WaiverTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id         String   @id @default(cuid())
  gymId      String
  action     String
  actorId    String?
  actorName  String?
  targetId   String?
  targetName String?
  meta       String?
  createdAt  DateTime @default(now())
  gym        Gym      @relation(fields: [gymId], references: [id], onDelete: Cascade)

  @@index([gymId, createdAt])
  @@index([gymId, action])
  @@index([createdAt])
}

model EmailCampaign {
  id        String          @id @default(cuid())
  subject   String
  html      String
  audience  String          @default("all_students")
  status    String          @default("draft")
  sentCount Int             @default(0)
  sentAt    DateTime?
  createdBy String?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  events    CampaignEvent[]

  @@index([createdAt])
}

model CampaignEvent {
  id         String        @id @default(cuid())
  campaignId String
  email      String
  event      String
  metadata   String?
  createdAt  DateTime      @default(now())
  campaign   EmailCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([event])
  @@index([campaignId, email, event])
}

model EmailUnsubscribe {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())

  @@index([email])
}

model GymDatabase {
  id            String   @id @default(cuid())
  name          String
  ownerName     String?
  email         String?
  phone         String?
  website       String?
  address       String?
  city          String?
  state         String?
  zip           String?
  rating        Float?
  reviewCount   Int?
  categories    String?
  socialMedia   String?
  lat           Float?
  lng           Float?
  status        String   @default("lead")
  notes         String?
  source        String   @default("google_maps")
  googlePlaceId String?  @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([state])
  @@index([city, state])
  @@index([createdAt])
}
